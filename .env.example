APP_NAME=Klass
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

SANCTUM_EXPIRATION_MINUTES=43200

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --------------------------------------------------------------------------
# Database — Supabase PostgreSQL
# --------------------------------------------------------------------------
# Dapatkan kredensial dari Supabase Dashboard → Settings → Database
# --------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# --------------------------------------------------------------------------
# Media Generator - Python Service
# --------------------------------------------------------------------------
# Untuk deploy terpisah, isi BASE_URL dengan URL Hugging Face Space milik
# service Python, misalnya: https://your-space-name.hf.space
# Shared secret harus sama antara backend Laravel dan Python service.
# Untuk rotasi tanpa downtime: deploy Python service dengan secret baru di
# MEDIA_GENERATION_PYTHON_SHARED_SECRET dan secret lama di
# MEDIA_GENERATION_PYTHON_SHARED_SECRET_PREVIOUS, lalu update backend ini ke
# secret baru yang sama. Setelah rollout stabil, hapus secret previous.
# --------------------------------------------------------------------------
MEDIA_GENERATION_PYTHON_BASE_URL=https://YOUR_MEDIA_GENERATOR_SPACE.hf.space
MEDIA_GENERATION_PYTHON_GENERATE_PATH=/v1/generate
MEDIA_GENERATION_PYTHON_HEALTH_PATH=/v1/health
MEDIA_GENERATION_PYTHON_PROVIDER=klass-python
MEDIA_GENERATION_PYTHON_MODEL=renderer-v1
MEDIA_GENERATION_PYTHON_SHARED_SECRET=CHANGE_ME_SHARED_SECRET
MEDIA_GENERATION_PYTHON_TIMEOUT_SECONDS=60
MEDIA_GENERATION_PYTHON_CONNECT_TIMEOUT_SECONDS=10
MEDIA_GENERATION_PYTHON_RETRY_ATTEMPTS=2
MEDIA_GENERATION_PYTHON_RETRY_SLEEP_MILLISECONDS=500

# --------------------------------------------------------------------------
# Media Generator - LLM Adapter Service
# --------------------------------------------------------------------------
# Backend Laravel memanggil llm-adapter-service untuk /v1/interpret dan
# /v1/respond. Adapter memegang provider LLM seperti Gemini/OpenAI, sedangkan
# backend tetap memanggil Python renderer secara terpisah untuk /v1/generate.
# Contoh host Hugging Face Space adapter:
# https://klass-llm-adapter-prod.hf.space
# --------------------------------------------------------------------------
MEDIA_GENERATION_LLM_ADAPTER_BASE_URL=https://klass-llm-adapter-prod.hf.space
MEDIA_GENERATION_LLM_ADAPTER_HEALTH_PATH=/v1/health
MEDIA_GENERATION_LLM_ADAPTER_SHARED_SECRET=CHANGE_ME_ADAPTER_SHARED_SECRET
MEDIA_GENERATION_LLM_ADAPTER_REQUEST_MAX_AGE_SECONDS=300
MEDIA_GENERATION_LLM_ADAPTER_CLOCK_SKEW_SECONDS=30
MEDIA_GENERATION_LLM_ADAPTER_SERVICE_NAME=llm-adapter-service
MEDIA_GENERATION_LLM_ADAPTER_SERVICE_VERSION=

MEDIA_GENERATION_INTERPRETER_PATH=/v1/interpret
MEDIA_GENERATION_INTERPRETER_PROVIDER=llm-adapter
MEDIA_GENERATION_INTERPRETER_MODEL=adapter-managed
MEDIA_GENERATION_INTERPRETER_TIMEOUT_SECONDS=30
MEDIA_GENERATION_INTERPRETER_CONNECT_TIMEOUT_SECONDS=10
MEDIA_GENERATION_INTERPRETER_RETRY_ATTEMPTS=2
MEDIA_GENERATION_INTERPRETER_RETRY_SLEEP_MILLISECONDS=250

MEDIA_GENERATION_DELIVERY_PATH=/v1/respond
MEDIA_GENERATION_DELIVERY_PROVIDER=llm-adapter
MEDIA_GENERATION_DELIVERY_MODEL=adapter-managed
MEDIA_GENERATION_DELIVERY_TIMEOUT_SECONDS=30
MEDIA_GENERATION_DELIVERY_CONNECT_TIMEOUT_SECONDS=10
MEDIA_GENERATION_DELIVERY_RETRY_ATTEMPTS=2
MEDIA_GENERATION_DELIVERY_RETRY_SLEEP_MILLISECONDS=250

# --------------------------------------------------------------------------
# Media Generator - Queue Worker
# --------------------------------------------------------------------------
# Nilai-nilai ini dibaca oleh supervisord.conf untuk worker async generation.
# --------------------------------------------------------------------------
MEDIA_GENERATION_QUEUE_CONNECTION=database
MEDIA_GENERATION_QUEUE_NAME=media-generation
MEDIA_GENERATION_QUEUE_TRIES=3
MEDIA_GENERATION_QUEUE_TIMEOUT_SECONDS=300
MEDIA_GENERATION_QUEUE_BACKOFF_SECONDS=30
MEDIA_GENERATION_QUEUE_SLEEP_SECONDS=3
MEDIA_GENERATION_QUEUE_MAX_JOBS=250
MEDIA_GENERATION_QUEUE_MAX_TIME_SECONDS=3600
MEDIA_GENERATION_QUEUE_MEMORY_MB=256
MEDIA_GENERATION_QUEUE_CONCURRENCY=1
MEDIA_GENERATION_QUEUE_STOPWAIT_SECONDS=360

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --------------------------------------------------------------------------
# Supabase Storage (S3-Compatible API)
# --------------------------------------------------------------------------
# Supabase Storage menggunakan endpoint S3-compatible.
# Endpoint format: https://YOUR_PROJECT_REF.supabase.co/storage/v1/s3
# Access Key & Secret didapat dari Supabase Dashboard → Settings → API
# --------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_STORAGE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_SECRET=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=klass-storage
SUPABASE_STORAGE_ENDPOINT=https://YOUR_PROJECT_REF.supabase.co/storage/v1/s3
SUPABASE_STORAGE_REGION=ap-southeast-1

# --------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# --------------------------------------------------------------------------
# Comma-separated list of allowed origins for API requests.
# Examples: http://localhost:3000,https://your-app.vercel.app
# NOTE: When supports_credentials is true (default), '*' wildcard is not
# allowed. Set to a concrete list of origins instead.
# --------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173
CORS_SUPPORTS_CREDENTIALS=true
CORS_PREFLIGHT_MAX_AGE=86400

VITE_APP_NAME="${APP_NAME}"

# --------------------------------------------------------------------------
# Content Integrity
# --------------------------------------------------------------------------
CONTENT_INTEGRITY_ENABLED=true
CONTENT_INTEGRITY_THRESHOLD=0.75
CONTENT_INTEGRITY_REJECTION_STRATEGY=warn

# --------------------------------------------------------------------------
# Sentry APM (Performance Monitoring)
# --------------------------------------------------------------------------
# DSN dari Sentry.io project settings. Set kosong untuk disable.
# traces_sample_rate: 0.0-1.0 (0.5 = 50% request di-trace)
# profiles_sample_rate: 0.0-1.0 (0.2 = 20% request di-profile)
# --------------------------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_TRACES_SAMPLE_RATE=0.5
SENTRY_PROFILES_SAMPLE_RATE=0.2
SENTRY_TRACING_ENABLED=true
